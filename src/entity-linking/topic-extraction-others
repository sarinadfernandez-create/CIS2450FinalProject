"""
Extract candidate topic phrases from external signal sources using KeyBERT.
These become your FEATURES — how much signal is there for topic X this week?

Input:  data/external/*.csv (arXiv, HackerNews, Reddit, GitHub, Semantic Scholar)
Output: data/processed/candidate_phrases.csv
        Columns: phrase, score, source, date, week
"""
import warnings
warnings.filterwarnings("ignore")

import os
import polars as pl
from datetime import datetime
from keybert import KeyBERT

# Path setup
ROOT = os.path.dirname(os.path.dirname(os.path.abspath(__file__)))
EXT_DIR = os.path.join(ROOT, "data", "external")
OUT_DIR = os.path.join(ROOT, "data", "processed")
os.makedirs(OUT_DIR, exist_ok=True)
OUT_PATH = os.path.join(OUT_DIR, "candidate_phrases.csv")

# KeyBERT config
TOP_N = 5           # fewer per document since we have many more docs here
NGRAM_RANGE = (1, 3)
DIVERSITY = 0.5

# Source configs: filename, text column(s), date column
SOURCES = {
    "arxiv": {
        "file": "arxiv.csv",
        "text_cols": ["title", "abstract"],
        "date_col": "published",
    },
    "semantic_scholar": {
        "file": "semantic_scholar.csv",
        "text_cols": ["title", "abstract"],
        "date_col": "published",
    },
    "hackernews": {
        "file": "hackernews.csv",
        "text_cols": ["title"],
        "date_col": "published",
    },
    "reddit": {
        "file": "reddit.csv",
        "text_cols": ["title", "text"],
        "date_col": "published",
    },
    "github": {
        "file": "github.csv",
        "text_cols": ["name", "description", "topics"],
        "date_col": "published",
    },
}

# Limit rows per source to keep runtime reasonable (especially for arXiv and Semantic Scholar which have many documents)
MAX_ROWS = {
    "arxiv": 20000,
    "semantic_scholar": 20000,
    "hackernews": None,
    "reddit": None,
    "github": None,
}


def week_of(date_str: str) -> str:
    try:
        d = datetime.strptime(date_str[:10], "%Y-%m-%d")
        iso = d.isocalendar()
        return f"{iso[0]}-W{iso[1]:02d}"
    except Exception:
        return ""


def load_source(source_name: str, config: dict) -> pl.DataFrame:
    path = os.path.join(EXT_DIR, config["file"])
    if not os.path.exists(path):
        print(f"  Skipping {source_name} — file not found at {path}")
        return pl.DataFrame()

    df = pl.read_csv(path, infer_schema_length=1000)

    #combine text columns into one
    text_cols = [c for c in config["text_cols"] if c in df.columns]
    if not text_cols:
        print(f"  Skipping {source_name} — no text columns found")
        return pl.DataFrame()

    df = df.with_columns(
        pl.concat_str([pl.col(c).fill_null("") for c in text_cols], separator=" ")
        .alias("combined_text")
    )

    #normalize date column
    date_col = config["date_col"]
    if date_col in df.columns:
        df = df.rename({date_col: "date"})
    else:
        df = df.with_columns(pl.lit("").alias("date"))

    df = df.filter(pl.col("combined_text").str.len_chars() > 20)

    #sample if needed
    max_rows = MAX_ROWS.get(source_name)
    if max_rows and len(df) > max_rows:
        df = df.sample(n=max_rows, seed=42)
        print(f"  Sampled {max_rows} rows from {len(df)} total")

    return df.select(["combined_text", "date"])


def extract_phrases(kw_model: KeyBERT, df: pl.DataFrame, source: str) -> list[dict]:
    records = []
    texts = df["combined_text"].to_list()
    dates = df["date"].to_list()

    for i, (text, date) in enumerate(zip(texts, dates)):
        if not text or len(text) < 20:
            continue
        try:
            keywords = kw_model.extract_keywords(
                text,
                keyphrase_ngram_range=NGRAM_RANGE,
                stop_words="english",
                use_mmr=True,
                diversity=DIVERSITY,
                top_n=TOP_N,
            )
            for phrase, score in keywords:
                records.append({
                    "phrase": phrase.lower().strip(),
                    "score": round(score, 4),
                    "source": source,
                    "date": str(date)[:10],
                    "week": week_of(str(date)),
                })
        except Exception as e:
            print(f"  Error on row {i}: {e}")
            continue

        if (i + 1) % 1000 == 0:
            print(f"  Processed {i+1}/{len(texts)} documents")

    return records


def main():
    print("Loading KeyBERT model...")
    kw_model = KeyBERT(model="all-MiniLM-L6-v2")
    print("Model loaded.\n")

    all_records = []

    for i, (source_name, config) in enumerate(SOURCES.items()):
        print(f"[{i+1}/{len(SOURCES)}] {source_name}")
        df = load_source(source_name, config)
        if df.is_empty():
            continue
        print(f"  {len(df)} documents to process")
        records = extract_phrases(kw_model, df, source_name)
        print(f"  Extracted {len(records)} phrases")
        all_records.extend(records)
        pl.DataFrame(all_records).sort(["date", "score"], descending=[False, True]).write_csv(OUT_PATH)
        print(f"  Checkpoint saved ({len(all_records)} total phrases so far)")
    

    combined = pl.DataFrame(all_records)
    combined = combined.sort(["date", "score"], descending=[False, True])
    combined.write_csv(OUT_PATH)

    print(f"\nDone. Saved {len(combined)} phrases -> {OUT_PATH}")
    print(f"Unique phrases: {combined['phrase'].n_unique()}")
    print(f"Date range: {combined['date'].min()} to {combined['date'].max()}")
    print("\nPhrases per source:")
    print(
        combined.group_by("source")
        .agg(pl.len().alias("count"))
        .sort("count", descending=True)
    )


if __name__ == "__main__":
    main()